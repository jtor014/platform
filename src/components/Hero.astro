---
interface Props {
  heading: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
}

const { heading, subtitle, ctaText, ctaHref } = Astro.props;
---

<section class="py-16 md:py-20">
  <h1 class="text-4xl md:text-5xl font-bold leading-tight mb-4">{heading}</h1>
  {subtitle && <p class="text-xl text-text-secondary mb-8 max-w-[600px]">{subtitle}</p>}
  {ctaText && ctaHref && (
    <a
      href={ctaHref}
      class="inline-block bg-primary hover:bg-primary-dark text-white font-semibold py-3 px-6 rounded-md transition-colors min-h-[44px]"
    >
      {ctaText}
    </a>
  )}
</section>
