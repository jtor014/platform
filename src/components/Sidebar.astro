---
import { getNavSections } from '../data/manifest';
import type { NavItem } from '../data/manifest';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const sections = getNavSections();

function isActive(href: string): boolean {
  return currentPath === href;
}

function isExpanded(item: NavItem): boolean {
  if (isActive(item.href)) return true;
  if (item.children) {
    return item.children.some((child) => isExpanded(child));
  }
  return false;
}

---

<nav class="sidebar-nav h-full overflow-y-auto py-6 px-4">
  <a href="/" class:list={[
    "flex items-center gap-2 px-3 py-2 mb-4 text-lg font-bold",
    isActive('/') ? 'text-sidebar-active-text' : 'text-sidebar-text hover:text-sidebar-active-text'
  ]}>
    The Platform
  </a>

  {sections.map((section) => (
    <div class="mb-2">
      <div class="px-3 py-2 text-xs font-semibold uppercase tracking-wider text-text-muted">
        {section.label}
      </div>
      <ul class="space-y-0.5">
        {section.children.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[
                "block px-3 py-1.5 rounded text-sm transition-colors",
                isActive(item.href)
                  ? 'bg-sidebar-active-bg text-sidebar-active-text font-medium'
                  : 'text-sidebar-text hover:bg-sidebar-active-bg/50 hover:text-sidebar-active-text'
              ]}
            >
              {item.label}
            </a>
            {item.children && isExpanded(item) && (
              <ul class="ml-3 mt-0.5 border-l border-sidebar-active-bg pl-3 space-y-0.5">
                {item.children.map((child) => (
                  <li>
                    <a
                      href={child.href}
                      class:list={[
                        "block px-3 py-1.5 rounded text-sm transition-colors",
                        isActive(child.href)
                          ? 'bg-sidebar-active-bg text-sidebar-active-text font-medium'
                          : 'text-sidebar-text hover:bg-sidebar-active-bg/50 hover:text-sidebar-active-text'
                      ]}
                    >
                      {child.label}
                    </a>
                    {child.children && isExpanded(child) && (
                      <ul class="ml-3 mt-0.5 border-l border-sidebar-active-bg pl-3 space-y-0.5">
                        {child.children.map((grandchild) => (
                          <li>
                            <a
                              href={grandchild.href}
                              class:list={[
                                "block px-3 py-1 rounded text-xs transition-colors",
                                isActive(grandchild.href)
                                  ? 'bg-sidebar-active-bg text-sidebar-active-text font-medium'
                                  : 'text-sidebar-text hover:bg-sidebar-active-bg/50 hover:text-sidebar-active-text'
                              ]}
                            >
                              {grandchild.label}
                            </a>
                            {grandchild.children && isExpanded(grandchild) && (
                              <ul class="ml-3 mt-0.5 border-l border-sidebar-active-bg pl-3 space-y-0.5">
                                {grandchild.children.map((ggchild: NavItem) => (
                                  <li>
                                    <a
                                      href={ggchild.href}
                                      class:list={[
                                        "block px-3 py-1 rounded text-xs transition-colors",
                                        isActive(ggchild.href)
                                          ? 'bg-sidebar-active-bg text-sidebar-active-text font-medium'
                                          : 'text-sidebar-text hover:bg-sidebar-active-bg/50 hover:text-sidebar-active-text'
                                      ]}
                                    >
                                      {ggchild.label}
                                    </a>
                                  </li>
                                ))}
                              </ul>
                            )}
                          </li>
                        ))}
                      </ul>
                    )}
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
    </div>
  ))}
</nav>
