---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
---

<BaseLayout title="Home">
  <main class="max-w-[720px] mx-auto px-6 py-16">
    <h1 class="text-4xl font-bold mb-4 text-[#0F172A]">The Platform</h1>
    <p class="text-lg text-[#475569] mb-8">Build real software. Direct AI to do it.</p>
    <div class="rounded-lg border border-[#E2E8F0] p-6 bg-[#F8FAFC]">
      <h2 class="text-xl font-semibold mb-2">Setup complete</h2>
      <p class="text-[#475569]">Astro + Tailwind CSS are working. This test page will be removed before merging.</p>
    </div>
  </main>
</BaseLayout>
