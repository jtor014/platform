    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-bg-muted">
          <th class="text-left px-4 py-3 font-semibold border-b border-border">Decision</th>
          <th class="text-left px-4 py-3 font-semibold border-b border-border">Choice</th>
          <th class="text-left px-4 py-3 font-semibold border-b border-border">Why</th>
        </tr>
      </thead>
      <tbody>
        <tr class="border-b border-border">
          <td class="px-4 py-3">EC2 instance size</td>
          <td class="px-4 py-3 text-text-secondary">t2.micro</td>
          <td class="px-4 py-3 text-text-secondary">Free tier eligible. Handles 200 concurrent users. Can resize later if needed.</td>
        </tr>
